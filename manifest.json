{
  "manifest_version": 3,
  "name": "LU Central Monitor",
  "description": "Automação para monitoração de LiveU",
  "version": "1.9.0",
  "permissions": [
    "notifications", 
    "storage", 
    "scripting", 
    "activeTab"
  ],
  "host_permissions": [
    "https://lu-central.liveu.tv/*",
    "https://*.liveu.tv/*",
    "http://10.51.253.6:3000/*" 
  ],
  "web_accessible_resources": [
    {
      "resources": ["js/audio-core.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "html/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.liveu.tv/*"],
      "js": ["js/content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}